// CATalyst AI — Production PostgreSQL schema
// Setup: npx prisma migrate dev --name init
// Requires: DATABASE_URL in .env.local

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  avatarUrl   String?
  role        Role     @default(USER)
  xp          Int      @default(0)
  streak      Int      @default(0)
  level       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscription      Subscription?
  videoProgress     VideoProgress[]
  watchSessions     VideoWatchSession[]
  xpEvents          XpEvent[]
  quizAttempts      QuizAttempt[]
  savedVideos       SavedVideo[]
  playlists         Playlist[]
  analyticsEvents   AnalyticsEvent[]
  auditLogs         AdminAuditLog[]  @relation("AuditActor")
  
  // AI Mentor relations
  conversations     Conversation[]
  memories          Memory[]
  aiUsage           AIUsage[]
  studySessions     StudySession[]
  studyStreak       StudyStreak?
  aiChallenges      AIChallenge[]

  @@index([email])
  @@index([role])
}

enum Role {
  USER
  ADMIN
}

// ─────────────────────────────────────────────────────────────────────────────
// SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id             String           @id @default(cuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           Plan             @default(FREE)
  status         SubscriptionStatus @default(ACTIVE)
  activatedAt    DateTime         @default(now())
  expiresAt      DateTime?
  razorpaySubId  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
  @@index([plan, status])
}

enum Plan {
  FREE
  PRO
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

// ─────────────────────────────────────────────────────────────────────────────
// VIDEOS
// ─────────────────────────────────────────────────────────────────────────────

model Video {
  id             String        @id @default(cuid())
  youtubeId      String?
  title          String
  instructor     String
  description    String        @db.Text
  aiSummary      String?       @db.Text
  keyTakeaways   String[]
  duration       String
  views          String
  rating         Float         @default(4.5)
  category       VideoCategory
  access         VideoAccess   @default(FREE)
  status         VideoStatus   @default(DRAFT)
  featured       Boolean       @default(false)
  order          Int           @default(0)
  tags           String[]
  xpToastMessage String?
  thumbnailUrl   String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  progress       VideoProgress[]
  watchSessions  VideoWatchSession[]
  quizQuestions  QuizQuestion[]
  quizAttempts   QuizAttempt[]
  savedBy        SavedVideo[]
  playlistItems  PlaylistItem[]
  analyticsEvents AnalyticsEvent[]
  auditLogs      AdminAuditLog[]

  @@index([category])
  @@index([status, deletedAt])
  @@index([access])
  @@index([featured])
  @@index([order])
}

enum VideoCategory {
  QA
  VARC
  DILR
  STRATEGY
}

enum VideoAccess {
  FREE
  PRO
  ELITE
}

enum VideoStatus {
  DRAFT
  PUBLISHED
}

// ─────────────────────────────────────────────────────────────────────────────
// WATCH PROGRESS
// ─────────────────────────────────────────────────────────────────────────────

model VideoProgress {
  id             String    @id @default(cuid())
  userId         String
  videoId        String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video          Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  progressPct    Float     @default(0)
  watchedSeconds Int       @default(0)
  xpAwarded      Boolean   @default(false)
  completedAt    DateTime?
  lastWatchedAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
  @@index([progressPct])
}

model VideoWatchSession {
  id           String   @id @default(cuid())
  userId       String
  videoId      String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  durationSecs Int      @default(0)
  deviceType   String?
  userAgent    String?

  @@index([userId])
  @@index([videoId])
  @@index([startedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// QUIZ
// ─────────────────────────────────────────────────────────────────────────────

model QuizQuestion {
  id           String   @id @default(cuid())
  videoId      String
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  question     String   @db.Text
  options      String[]
  correctIndex Int
  explanation  String   @db.Text
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([videoId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  videoId     String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  score       Int
  total       Int
  xpAwarded   Boolean  @default(false)
  xpAmount    Int      @default(0)
  completedAt DateTime @default(now())

  @@index([userId])
  @@index([videoId])
}

// ─────────────────────────────────────────────────────────────────────────────
// XP & GAMIFICATION
// ─────────────────────────────────────────────────────────────────────────────

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  sourceId  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SAVED VIDEOS & PLAYLISTS
// ─────────────────────────────────────────────────────────────────────────────

model SavedVideo {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())

  @@unique([userId, videoId])
  @@index([userId])
}

model Playlist {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     PlaylistItem[]

  @@index([userId])
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  videoId    String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  order      Int      @default(0)
  addedAt    DateTime @default(now())

  @@unique([playlistId, videoId])
  @@index([playlistId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  videoId   String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  video     Video?   @relation(fields: [videoId], references: [id], onDelete: SetNull)
  event     String
  metadata  Json?
  ipHash    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([videoId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// ADMIN AUDIT LOG
// ─────────────────────────────────────────────────────────────────────────────

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String
  resourceId String?
  videoId    String?
  video      Video?   @relation(fields: [videoId], references: [id], onDelete: SetNull)
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI CONVERSATIONS & MEMORY
// ─────────────────────────────────────────────────────────────────────────────

model Conversation {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String    @default("New Conversation")
  topic       String?   @default("general")
  isPinned    Boolean   @default(false)
  isFavorite  Boolean   @default(false)
  deletedAt   DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  messages    Message[]
  memories    Memory[]
  metadata    Json?     // Usage stats, model info, etc.

  @@unique([userId, id])
  @@index([userId])
  @@index([createdAt])
  @@index([isPinned])
  @@index([deletedAt])
}

model Message {
  id              String      @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String      @db.Text
  embedding       Json?       // JSON vector for semantic memory experiments
  metadata        Json?       // Provider info, tokens, latency, model, etc.
  feedback        String?     // user|helpful|unhelpful|flagged
  flagReason      String?
  regeneratedFrom String?     // ID of previous message if regenerated
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@index([feedback])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Memory {
  id                  String    @id @default(cuid())
  userId              String
  conversationId      String?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation        Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  
  summary             String    @db.Text  // Long-term memory summary
  embedding           Json?     // JSON vector for semantic similarity search
  isManuallyPinned    Boolean   @default(false)
  relatedTopics       String[]  @default([])
  mentionCount        Int       @default(1)
  lastAccessedAt      DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  expiresAt           DateTime? // Optional auto-deletion date

  @@index([userId])
  @@index([conversationId])
  @@index([lastAccessedAt])
  @@index([isManuallyPinned])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI USAGE & COSTS
// ─────────────────────────────────────────────────────────────────────────────

model AIUsage {
  id              String    @id @default(cuid())
  userId          String
  conversationId  String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  provider        String    // "groq" | "openrouter" | "gemini" | "ollama"
  model           String
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  costUSD         Float     @default(0)
  latencyMs       Int       @default(0)
  status          String    @default("success") // "success" | "error" | "timeout"
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([provider])
  @@index([createdAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI ENGAGEMENT & LEARNING
// ─────────────────────────────────────────────────────────────────────────────

model StudySession {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  topic         String
  durationMins  Int       @default(0)
  xpEarned      Int       @default(0)
  sessionType   String    // "free_chat" | "study_plan" | "mock_test_analysis" | "flashcard" | "revision"
  focusedWeaknesses String[]
  performanceScore Int?   // 0-100
  moodBefore    String?   // "confident" | "anxious" | "tired" | "neutral"
  moodAfter     String?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([sessionType])
}

model StudyStreak {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastStudyDate DateTime  @default(now())
  totalSessions Int       @default(0)
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model AIChallenge {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title         String
  description   String    @db.Text
  targetTopics  String[]
  difficulty    String    // "easy" | "medium" | "hard"
  status        String    @default("active") // "active" | "completed" | "abandoned"
  xpReward      Int       @default(100)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([status])
}
